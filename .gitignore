# Dependencies
node_modules/

# Frontend build output
dist/
build/

# Vendored / prebuilt third-party libraries (downloaded locally, not tracked)
pdfjs-prebuilt/

# Local databases (large, rebuilt from sync scripts)
*.sqlite
*.sqlite-shm
*.sqlite-wal
*.sqlite.bak*
*.bak-*

# D1 export artifact (large, regenerated by `npm run build:d1`; loaded via wrangler)
web/d1/data.sql

# D1 surgical-patch SQL (regenerated by web/scripts/build-d1-patch.cjs per deploy)
web/d1/patch-*.sql

# Entity search index (build-time generated by `npm run build:search`)
web/public/entity-index.json

# Downloaded raster data (regenerable: download-soilgrids-cogs.sh and sync-climate-grid.js)
backend/data/

# Source PDFs (~700 MB): agent corpus is the extracted text under .claude/agents/agroecologist/reference/
agroecology_books/
# Renamed 2026-05-01 to literature/ — same intent (corpus PDFs/EPUBs/XLSX are large
# and regenerable; only the extracted text under .claude/agents/agroecologist/reference/
# matters for agent invocations, and that's separately gitignored below).
# Ignore literature/ CONTENTS (not the dir itself) so the curated source manifest
# can be re-included — the acquisition-lock.json + all PDFs stay ignored.
literature/*
!literature/sources-manifest.json

# Bash-sandbox dotfile char-device artifacts (created by some tool calls; harmless
# but show as untracked).
backend/.claude/

# Process artifacts and logs
*.log
*.pid
test.gz

# Secrets and environment
.env
.env.local
.env.*.local
*.pem
*.key
*credentials*

# Per-user Claude state (note: .claude/agents/ IS tracked — prompt-as-data; do not ignore it).
# .claude/settings.json IS tracked (team-shared hooks/guardrails); personal overrides go in settings.local.json.
.claude/settings.local.json
.claude/.session.json
.claude/commands
.claude/skills
.superpowers/

# context-mode plugin local state — never publish (index DB may contain session transcripts)
.github/context-mode/
.github/hooks/

# Verbatim book extracts (copyright; agents reference them locally only).
# Regenerate via: node backend/tools/extract_corpus.js
.claude/agents/agroecologist/reference/*_full_text.md
# Structured-database corpus dumps (regenerable via backend/tools/extract_xlsx.py
# from the source XLSX in literature/; ICTV is CC0-equivalent but bulky).
.claude/agents/agroecologist/reference/*.tsv

# OS / editor metadata
.DS_Store
Thumbs.db
*:Zone.Identifier
.vscode/
.idea/
*.swp
*.swo

# Git worktrees (isolated implementation branches)
.worktrees/
backend/globi-interactions.tsv.gz

# Wrangler dev/build artifacts
.wrangler/

# Re-ingest campaign workspace (regenerated by multi-critic-batch-prepare.js;
# verdicts produced by subscription-mode agents per GUAM-REINGEST-RESUME.md)
backend/critic-batches/
backend/critic-verdicts/
backend/critic-batches-recovery/
backend/critic-verdicts-recovery/
backend/critic-batches-harvest/
backend/critic-verdicts-harvest/

# Per-doc extractor prompts + the JSON the dispatched Agents emit
# (regenerated by render-extractor-prompt.js, durable across /tmp wipes)
backend/reingest/

# Vouch (Haiku-tier) batch + verdict workspace
backend/vouch-batches/
backend/vouch-verdicts/

# Targeted DB-row backups from reset-sources-for-reingest.js
backend/backups/

# Critic-router fitness harness — regenerable baseline output (numbers live in the
# graduation ledger + journal; the JSON is reproducible via `npm run eval-router`)
backend/router-eval-*.json

# OKF knowledge bundle — internal-only descriptive map + engineering log.
# Deliberately NOT published to the public repo: log.md is session engineering
# exhaust and some decision concepts describe monetization/anti-scraping strategy.
# Kept on the internal working history; publish provenance docs deliberately if ever wanted.
.okf/
