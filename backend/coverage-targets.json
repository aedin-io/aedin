      { "label": "Sweet potato", "match": ["Ipomoea batatas"] },
      { "label": "Cucumber", "match": ["Cucumis sativus"] },
      { "label": "Melon", "match": ["Cucumis melo"] },
      { "label": "Walnut", "match": ["Juglans"] },
      { "label": "Peach / cherry / plum", "match": ["Prunus persica", "Prunus avium"] },
      { "label": "Pear", "match": ["Pyrus communis", "Pyrus"] },
      { "label": "Broccoli / cole crops", "match": ["Brassica oleracea"] }
