---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Not found">
  <div class="max-w-3xl mx-auto px-6 py-20 text-center">
    <h1 class="text-4xl font-semibold text-nature-900 mb-3">404 — entity not found</h1>
    <p class="text-earth-700">
      No verified claims for this slug. <a href="/" class="text-nature-700 hover:underline">Browse from the landing page</a>.
    </p>
  </div>
</Layout>
