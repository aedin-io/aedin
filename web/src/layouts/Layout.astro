---
import '../styles/global.css';
import ConsumerWarning from '../components/ConsumerWarning.astro';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
}
const { title, description, noindex } = Astro.props;
const fullTitle = title
  ? `${title} · AEDIN`
  : 'AEDIN — citable agroecological knowledge base';
const pageDescription = description
  ?? 'AI-multi-critic-verified agroecological claims with full source provenance. Built for academic researchers.';

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString().replace(/\/$/, '') || Astro.site!.toString();
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={pageDescription} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />

    <!-- OpenGraph -->
    <meta property="og:type" content={title ? 'article' : 'website'} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="AEDIN" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={pageDescription} />

    <!-- Sitemap discovery -->
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="border-b border-nature-700/20 bg-white" data-pagefind-ignore>
      <div class="max-w-5xl mx-auto px-6 py-4 flex items-center gap-6">
        <a href="/" class="no-underline shrink-0" aria-label="AEDIN — home">
          <img src="/assets/logo-lockup.svg" alt="AEDIN" width="300" height="72" class="h-8 w-auto" />
        </a>
        <nav class="flex gap-4 text-sm text-nature-700">
          <a href="/atlas" class="hover:underline">Atlas</a>
          <a href="/crop-web" class="hover:underline">Crop web</a>
          <a href="/data-sources" class="hover:underline">Data sources</a>
          <a href="/about" class="hover:underline">About</a>
          <a href="/api" class="hover:underline">API</a>
          <a href="/simulator/index.html" class="hover:underline">Simulator</a>
        </nav>
      </div>
    </header>
    <main class="flex-1">
      <slot />
    </main>
    <footer class="border-t border-nature-700/20 bg-white" data-pagefind-ignore>
      <div class="max-w-5xl mx-auto px-6 py-4">
        <ConsumerWarning />
        <nav class="mt-3 flex flex-wrap gap-x-4 gap-y-1 text-xs text-nature-700">
          <a href="/about" class="hover:underline">About</a>
          <a href="/data-sources" class="hover:underline">Data sources</a>
          <a href="/api" class="hover:underline">API</a>
          <a href="/terms" class="hover:underline">Terms</a>
        </nav>
      </div>
    </footer>
  </body>
</html>
